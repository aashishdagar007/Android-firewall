<?xml version="1.0" encoding="utf-8"?>
<!--
    data_extraction_rules.xml — Declares what data is backed up via cloud backup.
    We exclude sensitive firewall logs from cloud backup for privacy.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="file" path="logs/" />
        <exclude domain="file" path="config/" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="file" path="logs/" />
    </device-transfer>
</data-extraction-rules>
